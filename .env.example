# Токен бота от @BotFather
BOT_TOKEN=

# Секрет для проверки подписи webhook (опционально)
WEBHOOK_SECRET=

# Базовый URL приложения (для setWebhook), например https://your-app.vercel.app
NEXT_PUBLIC_APP_URL=

# OpenRouter API (по умолчанию бесплатная модель google/gemma-3-12b-it:free)
OPENROUTER_API_KEY=
# OPENROUTER_MODEL=   # необязательно; если не задано — используется бесплатная модель

# Google Custom Search JSON API (Programmable Search Engine)
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_CX=
